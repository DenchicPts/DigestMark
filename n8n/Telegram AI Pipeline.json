    {
      "parameters": {
        "promptType": "define",
        "text": "={{ $('Parse Classification').item.json.text }}",
        "options": {
          "systemMessage": "==You are an expert Obsidian note-making assistant. Your job is to transform raw transcribed text into a clean, dense, useful Obsidian note.\n\nRULES:\n- Output ONLY the note. Nothing before ---, nothing after the last line.\n- Keep the ORIGINAL LANGUAGE of the text (ru/en/mixed).\n- Remove ALL filler: repetitions, \"so\", \"basically\", \"you know\", verbal noise, meta-commentary (\"in this video I will...\"), sign-offs.\n- Keep ONLY facts, parameters, conclusions, actionable tips.\n- Use ## subheadings to group related ideas.\n- Use bullet points for lists of parameters/options.\n- Bold **key terms** and **values**.\n\nOUTPUT FORMAT — start your response with --- immediately:\n---\ntitle: {{ $('Parse Classification').item.json.classification.title }}\ndate: {{ new Date().toISOString().split('T')[0] }}\ncategory: {{ $('Parse Classification').item.json.classification.category }}\ntags: [{{ $('Parse Classification').item.json.classification.tags.join(', ') }}]\n---\n\n# {{ $('Parse Classification').item.json.classification.title }}\n\n## Summary\n<2-3 sentence dense summary of the main idea>\n\n## Key Points\n<structured content with ## subheadings and bullet points>\n\n## Takeaways\n<actionable conclusions, if any>"
        }
      },
      "id": "43f9bbad-08b4-4428-b160-b6a234913839",
      "name": "Agent: Format Note",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
        8608,
        3184
      ],
      "retryOnFail": true,
      "maxTries": 2,
      "waitBetweenTries": 5000
    },
    {
      "parameters": {
        "model": "nvidia/nemotron-3-super-120b-a12b:free",
        "options": {}
      },
      "id": "0fec12d5-6635-4bce-992a-2b07b620e99e",
      "name": "OpenRouter: Note Model",
      "type": "@n8n/n8n-nodes-langchain.lmChatOpenRouter",
      "typeVersion": 1,
      "position": [
        8608,
        3376
      ],
      "credentials": {
        "openRouterApi": {
          "id": "APIII",
          "name": "OpenRouter account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const noteContent = $json.output || '';\nconst prev = $('Parse Classification').item.json;\nconst cl = prev.classification;\n\n// Вытаскиваем title из первой строки frontmatter агента\n// Агент отдаёт: \"---\\ntitle: docker server\\n...\"\nlet titleFromNote = '';\nconst titleMatch = noteContent.match(/^---[\\s\\S]*?title:\\s*(.+)/m);\nif (titleMatch) {\n  titleFromNote = titleMatch[1].trim();\n}\n\n// Фоллбэк на classification.title\nconst rawTitle = titleFromNote || cl.title || 'note';\n\nconst safeTitle = rawTitle\n  .toLowerCase()\n  .replace(/[^a-zа-яё0-9\\s-]/gi, '')\n  .trim()\n  .replace(/\\s+/g, '-')\n  .substring(0, 60);\n\nconst category = cl.category || 'other';\nconst filename = `${safeTitle}.md`;\nconst filepath = `/obsidian/${category}/${filename}`;\n\nreturn [{ json: { ...prev, noteContent, filepath, filename, category } }];"
      },
      "id": "4516e509-d973-417a-b5e3-ed0ba9882348",
      "name": "Build File Path",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        8928,
        3168
      ]
    },
    {
      "parameters": {
        "jsCode": "const fs = require('fs');\nconst path = require('path');\n\nconst filepath = $json.filepath;\nconst content = $json.noteContent;\n\nif (!content) {\n  throw new Error('noteContent is empty — агент не вернул текст');\n}\n\nconst dir = path.dirname(filepath);\n\nif (!fs.existsSync(dir)) {\n  fs.mkdirSync(dir, { recursive: true });\n}\n\nfs.writeFileSync(filepath, content, 'utf8');\n\nreturn [{ json: $json }];"
      },
