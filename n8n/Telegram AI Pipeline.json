    {
      "parameters": {
        "method": "POST",
        "url": "http://192.168.24.120:9002/completion",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"system_prompt\": \"You are a strict text classifier. Output ONLY a valid JSON object. No text, no markdown, no explanation.\",\n  \"prompt\": \"Classify the text and return JSON.\\n\\nJSON structure:\\n{\\\"type\\\":\\\"note|question|task|plain\\\",\\\"category\\\":\\\"tech|linux|servers|programming|docker|networking|devops|sysadmin|security|database|cloud|hardware|idea|personal|finance|health|food|travel|language|science|other\\\",\\\"tags\\\":[\\\"tag1\\\",\\\"tag2\\\"],\\\"title\\\":\\\"short title\\\",\\\"lang\\\":\\\"ru|en|mixed\\\"}\\n\\nCLASSIFICATION RULES:\\n\\nSTEP 1 — Check length and structure:\\n- Text under 10 words AND no technical/factual content = plain or question\\n- Text over 80 words = almost always note (transcription, explanation, article)\\n- Text with spoken language markers ('я показал', 'смотрим', 'во-первых', 'то есть', 'собственно') = note\\n\\nSTEP 2 — Determine type:\\nplain = greetings, small talk, single words, emotional messages, no useful information\\n  Examples: 'Привет', 'как дела', 'окей', 'спасибо', 'Привет как тебя зовут?', 'пока'\\n  IMPORTANT: If text starts with greeting but contains useful content after — classify by the content NOT the greeting\\n\\nquestion = asks for a specific fact or answer, short direct questions\\n  Examples: 'сколько часов в неделе', 'что такое docker', 'как установить nginx', 'какой синтаксис у cron'\\n\\nnote = information worth saving: facts, instructions, how-tos, definitions, long explanations, transcriptions\\n  Examples: long technical text, video transcription, 'docker run -p 80:80 nginx запускает контейнер...'\\n\\ntask = action item, reminder, todo\\n  Examples: 'купить молоко', 'не забыть позвонить', 'обновить сервер до пятницы'\\n\\nIF IN DOUBT between plain and question — use question\\nIF IN DOUBT between plain and note — check length: over 30 words = note, under 30 = plain\\nIF IN DOUBT between question and note — over 50 words = note\\n\\nCATEGORY RULES:\\ntech = general technology topics\\nlinux = linux commands, bash, shell scripting\\nservers = server setup, nginx, apache, systemd, services\\nprogramming = code, algorithms, languages, frameworks\\ndocker = containers, docker-compose, images, volumes\\nnetworking = tcp/ip, dns, vpn, firewall, ports, protocols\\ndevops = ci/cd, pipelines, ansible, terraform, monitoring, deployment\\nsysadmin = system administration, users, permissions, backups, cron\\nsecurity = ssl, certificates, auth, vulnerabilities, hardening\\ndatabase = sql, postgres, mysql, redis, mongodb, queries\\ncloud = aws, gcp, azure, vps, s3, cloud services\\nhardware = cpu, gpu, ram, disk, physical components\\nidea = creative idea, concept, brainstorm\\npersonal = personal life, relationships, habits\\nfinance = money, budget, investments, expenses\\nhealth = medical, fitness, wellbeing\\nfood = recipes, nutrition, restaurants\\ntravel = places, trips, logistics\\nlanguage = grammar, translation, linguistics\\nscience = physics, math, biology, chemistry\\nother = does not fit any category\\n\\ntags: 2-3 lowercase keywords from actual content (not category names)\\ntitle: 3-6 words in same language as text\\nlang: ru / en / mixed\\n\\nText: {{ ($if($('Merge: Text').isExecuted, $('Merge: Text').item.json.text, '') || $if($('Merge: Media').isExecuted, $('Merge: Media').item.json.text, '') || $if($('Merge: URL').isExecuted, $('Merge: URL').item.json.text, '')).substring(0, 800) }}\",\n  \"temperature\": 0,\n  \"n_predict\": 200,\n  \"json_schema\": {\n    \"type\": \"object\",\n    \"properties\": {\n      \"type\":     { \"type\": \"string\", \"enum\": [\"note\",\"question\",\"task\",\"plain\"] },\n      \"category\": { \"type\": \"string\", \"enum\": [\"tech\",\"linux\",\"servers\",\"programming\",\"docker\",\"networking\",\"devops\",\"sysadmin\",\"security\",\"database\",\"cloud\",\"hardware\",\"idea\",\"personal\",\"finance\",\"health\",\"food\",\"travel\",\"language\",\"science\",\"other\"] },\n      \"tags\":     { \"type\": \"array\", \"items\": { \"type\": \"string\" }, \"minItems\": 2, \"maxItems\": 3 },\n      \"title\":    { \"type\": \"string\" },\n      \"lang\":     { \"type\": \"string\", \"enum\": [\"ru\",\"en\",\"mixed\"] }\n    },\n    \"required\": [\"type\",\"category\",\"tags\",\"title\",\"lang\"]\n  }\n}",
        "options": {
          "timeout": 120000
        }
      },
      "id": "d7426ace-98e5-474d-8724-e84473c40533",
      "name": "llama.cpp Classify",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        7808,
        3376
      ]
    },
    {
      "parameters": {
        "jsCode": "let classification;\ntry {\n  const raw = $json.content || $json.response || '{}';\n  classification = typeof raw === 'string' ? JSON.parse(raw) : raw;\n} catch(e) {\n  classification = { type: 'plain', category: 'other', tags: ['unclassified'], title: 'Без темы', lang: 'ru' };\n}\n\n// Тянем текст из всех источников\nconst prev = $('Status: Classifying').first().json;\nlet text = prev.text || '';\nif (!text) { try { text = $('Merge: Media').first().json.text || ''; } catch(e) {} }\nif (!text) { try { text = $('Merge: URL').first().json.text || ''; } catch(e) {} }\nif (!text) { try { text = $('Merge: Text').first().json.text || ''; } catch(e) {} }\n\n// Пост-обработка: исправляем ошибки модели\nconst wordCount = text.trim().split(/\\s+/).length;\nconst lowerText = text.toLowerCase().trim();\n\n// 1. Короткий текст — модель часто ошибается с note\nif (wordCount <= 10 && classification.type === 'note') {\n  const questionWords = ['что', 'как', 'где', 'когда', 'почему', 'зачем', 'сколько', 'какой', 'какая', 'какие', 'кто', 'чем', 'what', 'how', 'where', 'when', 'why', 'who', 'which'];\n  const hasQuestion = lowerText.includes('?') || questionWords.some(w => lowerText.startsWith(w) || lowerText.includes(' ' + w + ' '));\n  classification.type = hasQuestion ? 'question' : 'plain';\n}\n\n// 2. Приветствия с small talk — всегда plain\nconst greetings = ['привет', 'здравствуй', 'хай', 'салют', 'добрый день', 'добрый вечер', 'доброе утро', 'hello', 'hi ', 'hey '];\nconst smallTalk = ['как тебя зовут', 'как дела', 'что делаешь', 'ты кто', 'кто ты', 'как твои дела', 'what is your name', 'how are you'];\nif (wordCount <= 15 && greetings.some(g => lowerText.startsWith(g)) && smallTalk.some(p => lowerText.includes(p))) {\n  classification.type = 'plain';\n}\n\n// 3. Длинный текст — не может быть plain\nif (wordCount >= 80 && classification.type === 'plain') {\n  classification.type = 'note';\n}\n\nreturn [{ json: { ...prev, classification, text } }];"
      },
      "id": "32635a78-6c76-4389-8e36-b4ebcc52a8cc",
