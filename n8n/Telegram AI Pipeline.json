{
  "name": "Telegram AI Pipeline v6",
  "nodes": [
    {
      "parameters": {
        "jsCode": "const msg = $json.message;\nif (!msg) return [];\n\n// Только этот пользователь может использовать бота\nconst ALLOWED_USER_ID = 1111111;\nif (msg.from.id !== ALLOWED_USER_ID) return [];\n\nconst chatId = msg.chat.id;\nconst messageId = msg.message_id;\n\nlet contentType = 'unknown';\nlet content = '';\nlet fileId = null;\n\nif (msg.voice) {\n  contentType = 'media';\n  fileId = msg.voice.file_id;\n} else if (msg.video_note) {\n  contentType = 'media';\n  fileId = msg.video_note.file_id;\n} else if (msg.audio) {\n  contentType = 'media';\n  fileId = msg.audio.file_id;\n} else if (msg.video) {\n  contentType = 'media';\n  fileId = msg.video.file_id;\n} else if (msg.text) {\n  const urlPattern = /https?:\\/\\/(www\\.)?(youtube\\.com|youtu\\.be|tiktok\\.com|vimeo\\.com)\\S*/i;\n  const match = msg.text.match(urlPattern);\n  if (match) {\n    contentType = 'url';\n    content = match[0];\n  } else {\n    contentType = 'text';\n    content = msg.text;\n  }\n} else {\n  return [];\n}\n\nreturn [{ json: { chatId, messageId, contentType, content, fileId } }];"
      },
